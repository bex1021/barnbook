<button class="btn btn-outline-light buy-now">Get Yours</button>-->

<!-- Checkout Modal -->
<div class="modal fade" id="checkoutModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header border-0">
                <h5 class="modal-title h1">Ride and Lesson Pre-Pay</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body p-4">
                <!-- ========== View 1 – Cart ========== -->
                <div class="step" data-step="1">
                    <p class="text-muted">Please note - lessons and trail ride reservations need to be canceled at least 48 hours in advance to qualify for a refund. </p>
                    <h4 class="mb-3">Choose items</h4>
                    <div id="productList" class="pb-3"></div>
                    <div class="text-end pt-4">
                        <button class="btn btn-primary next">Next</button>
                    </div>
                </div>

                <!-- ========== View 2 – Customer details ========== -->
                <div class="step d-none" data-step="2">
                    <h4 class="mb-3">Contact</h4>
                    <p class="fw-semibold">Order total: <span id="orderTotal"></span></p>

                    <form id="custForm" class="row gy-3 gx-4">

                        <!-- Contact -->
                        <div class="col-md-12">
                            <label class="form-label" for="custName">
                                Full Name <span class="text-danger">*</span>
                            </label>
                            <input id="custName" name="name" class="form-control" placeholder="John Doe" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" for="custEmail">
                                Email <span class="text-danger">*</span>
                            </label>
                            <input id="custEmail" name="email" type="email" class="form-control" placeholder="john@example.com" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" for="custPhone">
                                Phone <span class="text-danger">*</span>
                            </label>
                            <input id="custPhone" name="phone" class="form-control" placeholder="+1 555-123-4567" required>
                        </div>

                        <!-- Address -->
                        <div class="col-12">
                            <label class="form-label" for="addrLine1">
                                Street Address <span class="text-danger">*</span>
                            </label>
                            <input id="addrLine1" name="line1" class="form-control" placeholder="123 Forest Trail" required>
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="addrLine2">
                                Apt / Suite # <!-- optional, so no asterisk -->
                            </label>
                            <input id="addrLine2" name="line2" class="form-control" placeholder="Unit B">
                        </div>

                        <div class="col-md-6 col-lg-4">
                            <label class="form-label" for="addrCity">
                                City <span class="text-danger">*</span>
                            </label>
                            <input id="addrCity" name="city" class="form-control" required>
                        </div>

                        <div class="col-md-3 col-lg-4">
                            <label class="form-label" for="addrState">
                                State / Province <span class="text-danger">*</span>
                            </label>
                            <input id="addrState" name="state" class="form-control" required>
                        </div>

                        <div class="col-md-3 col-lg-4">
                            <label class="form-label" for="addrZip">
                                ZIP / Postal <span class="text-danger">*</span>
                            </label>
                            <input id="addrZip" name="zip" class="form-control" required>
                        </div>

                        <input type="hidden" name="country" value="US">
                    </form>



                    <div class="d-flex justify-content-between pt-4">
                        <button class="btn btn-secondary prev">Back</button>
                        <button id="submitOrder" type="button" class="btn btn-primary">
                            Submit Order and Pay
                        </button>
                    </div>
                </div>

            </div><!-- /.modal-body -->

            <!-- FOOTER -->
            <div class="modal-footer bg-light border-0">
                <small class="text-muted">Secure payments by Stripe</small>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    (() => {
        /* ---------- Product Config ---------- */
        const productList = [{"id":"product_1","name":"1 hr Lesson","note":"Max 3 riders","price":8000,"image":"assets\/files\/data_products\/1\/main\/lesson.webp"},{"id":"product_2","name":"1 hr Lesson (Pay for 5, Ride 6)","note":"Max 3 riders","price":40000,"image":"assets\/files\/data_products\/2\/main\/lesson1.webp"},{"id":"product_3","name":" 1 hr Trail Ride","note":"Max 3 riders","price":9000,"image":"assets\/files\/data_products\/3\/main\/trail1.webp"},{"id":"product_4","name":"1.5 hr Trail Ride","note":"Max 3 riders","price":12500,"image":"assets\/files\/data_products\/4\/main\/about.webp"},{"id":"product_5","name":"2 hr Trail Ride","note":"Max 3 riders","price":15000,"image":"assets\/files\/data_products\/5\/main\/trail2.webp"}];

        /* ---------- Modal + Step Logic ---------- */
        const modalElem = document.getElementById('checkoutModal');
        const modal = new bootstrap.Modal(modalElem);
        const steps = Array.from(document.querySelectorAll('.step'));
        let active = 0;
        const orderData = {};

        // Open modal
        document.querySelectorAll('.buy-now')
            .forEach(btn => btn.addEventListener('click', () => modal.show()));

        // Nav buttons
        const nextButton = document.querySelector('.next');
        
        // Function to check if at least one item has quantity > 0
        function hasItems() {
            let hasItems = false;
            document.querySelectorAll('.qty').forEach(i => {
                if (+i.value > 0) {
                    hasItems = true;
                }
            });
            return hasItems;
        }
        
        // Function to update Next button state
        function updateNextButton() {
            if (hasItems()) {
                nextButton.disabled = false;
                nextButton.classList.remove('btn-secondary');
                nextButton.classList.add('btn-primary');
            } else {
                nextButton.disabled = true;
                nextButton.classList.remove('btn-primary');
                nextButton.classList.add('btn-secondary');
            }
        }
        
        nextButton.addEventListener('click', () => {
            if (!hasItems()) {
                return; // Don't proceed if no items
            }
            calcTotal();
            goTo(1);
        });

        document.querySelector('.prev').addEventListener('click', () => {
            goTo(0);
            updateNextButton(); // Update button state when going back
        });

        function goTo(n) {
            steps[active].classList.add('d-none');
            steps[n].classList.remove('d-none');
            active = n;
        }

        /* ---------- Render Product List ---------- */
        const productListContainer = document.getElementById('productList');
        productList.forEach(product => {
            const row = document.createElement('div');
            row.className = "row g-3 align-items-center justify-content-between border-bottom pb-3 mb-3";

            row.innerHTML = `
            <div class="col-lg-3 col-8">
                <img src="${product.image}" class="img-fluid rounded" alt="${product.name}" style="max-width: 150px;">
            </div>
            <div class="col-lg-5 col-8">
                <h5 class="mb-0 pt-2">${product.name}</h5>
                <small class="text-muted">${product.note}</small><br>
                <small class="text-muted">$${(product.price / 100).toFixed(2)} / rider</small>
            </div>
            <div class="col-4">
                <input type="number" min="0" value="0"
                    class="form-control qty"
                    data-id="${product.id}"
                    data-name="${product.name}"
                    data-price="${product.price}">
            </div>
        `;

            productListContainer.appendChild(row);
        });
        
        // Add event listeners to all quantity inputs to update Next button state
        // Use event delegation since inputs are added dynamically
        productListContainer.addEventListener('input', (e) => {
            if (e.target.classList.contains('qty')) {
                updateNextButton();
            }
        });
        
        // Also check on change event
        productListContainer.addEventListener('change', (e) => {
            if (e.target.classList.contains('qty')) {
                updateNextButton();
            }
        });
        
        // Initially disable Next button after products are rendered
        updateNextButton();

        /* ---------- Cart Logic ---------- */
        function calcTotal() {
            let total = 0;
            let items = [];

            document.querySelectorAll('.qty').forEach(i => {
                const qty = +i.value;
                if (!qty) return;

                const price = +i.dataset.price;
                items.push({
                    id: i.dataset.id,
                    name: i.dataset.name,
                    qty,
                    price
                });
                total += qty * price;
            });

            orderData.items = items;
            orderData.amount = total;

            document.getElementById('orderTotal').textContent =
                `$${(total / 100).toFixed(2)}`;
        }

        /* ---------- Submit to /checkout ---------- */
        const custForm = document.getElementById('custForm');

        document.getElementById('submitOrder').addEventListener('click', () => {
            if (!custForm.reportValidity()) return;

            Object.assign(orderData,
                Object.fromEntries(new FormData(custForm).entries()));

            const hiddenItems = document.createElement('input');
            hiddenItems.type = 'hidden';
            hiddenItems.name = 'items';
            hiddenItems.value = JSON.stringify(orderData.items);

            const hiddenTotal = document.createElement('input');
            hiddenTotal.type = 'hidden';
            hiddenTotal.name = 'total_cents';
            hiddenTotal.value = orderData.amount;

            custForm.append(hiddenItems, hiddenTotal);

            custForm.action = 'checkout';
            custForm.method = 'post';
            custForm.submit();
            modal.hide();
        });

    })();
</script><footer class="pt-5 pb-3 border-top border-5 border-dark py-4">
