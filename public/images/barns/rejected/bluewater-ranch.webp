<!-- Cookie Banner & Preferences Modal ----------------------------------
    Requires Bootstrap 5 CSS and JS already loaded on the page
	include into foot file with:
 	include('system/components/cookie-settings/cookie-settings.php'); -->
<!-- 1️⃣  Banner  ------------------------------------------------------>
<div id="cookieBanner" class="cookie-banner position-fixed bottom-0 start-0 end-0 bg-dark text-white d-none" style="z-index:1100;">
    <div class="container py-3 d-flex flex-column flex-md-row align-items-center justify-content-between gap-2">
        <span class="small flex-grow-1">
            We use cookies to make this site work and collect analytics. Pick your preferences.
        </span>
        <div class="d-flex gap-2">
            <button id="btnAcceptAll" class="btn btn-primary btn-sm">Accept&nbsp;all</button>
            <button id="btnCustomize" class="btn btn-outline-light btn-sm" data-bs-toggle="modal" data-bs-target="#cookieModal">Customize</button>
        </div>
    </div>
</div>

<!-- 2️⃣  Preferences Modal ------------------------------------------->
<div class="modal fade" id="cookieModal" tabindex="-1" aria-labelledby="cookieModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="cookieModalLabel">Cookie preferences</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="cookieForm" class="vstack gap-3">
                    <!-- Essential (disabled/always on) -->
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="ckEssential" checked disabled>
                        <label class="form-check-label fw-bold" for="ckEssential">Essential cookies</label>
                        <p class="small text-muted mb-0">Required for basic site functionality.</p>
                    </div>
                    <!-- Analytics -->
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="ckAnalytics" checked>
                        <label class="form-check-label fw-bold" for="ckAnalytics">Analytics cookies</label>
                        <p class="small text-muted mb-0">Helps us understand how visitors use our site.</p>
                    </div>
                    <!-- Marketing -->
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="ckMarketing" checked>
                        <label class="form-check-label fw-bold" for="ckMarketing">Marketing cookies</label>
                        <p class="small text-muted mb-0">Used to deliver personalized ads.</p>
                    </div>
                    <!-- Functional -->
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="ckFunctional" checked>
                        <label class="form-check-label fw-bold" for="ckFunctional">Functional cookies</label>
                        <p class="small text-muted mb-0">Remember choices such as language or region.</p>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button id="btnSavePrefs" class="btn btn-primary">Save preferences</button>
            </div>
        </div>
    </div>
</div>

<!-- 3️⃣  Manage Link in Footer  -------------------------------------->
<a id="cookieManageLink" href="#" class="position-fixed bottom-0 end-0 m-3 small text-muted d-none" data-bs-toggle="modal" data-bs-target="#cookieModal" style="z-index:1050;">Cookie&nbsp;settings</a>

<!-- 4️⃣  Vanilla‑JS logic ------------------------------------------ -->
<script>
    (function() {
        const LS_KEY = 'cookiePrefs-v1';
        const defaults = {
            essential: true,
            analytics: true,
            marketing: true,
            functional: true
        };

        const banner = document.getElementById('cookieBanner');
        const manageLnk = document.getElementById('cookieManageLink');
        const form = document.getElementById('cookieForm');

        /* utils --------------------------------------------------------- */
        function loadPrefs() {
            try {
                return JSON.parse(localStorage.getItem(LS_KEY)) ?? null;
            } catch {
                return null;
            }
        }

        function savePrefs(p) {
            localStorage.setItem(LS_KEY, JSON.stringify(p));
        }

        /* Init ---------------------------------------------------------- */
        const saved = loadPrefs();
        if (!saved) {
            banner.classList.remove('d-none');
        } else {
            manageLnk.classList.remove('d-none');
            applyPrefs(saved);
        }

        /* Event handlers ------------------------------------------------ */
        document.getElementById('btnAcceptAll').addEventListener('click', () => {
            savePrefs({
                essential: true,
                analytics: true,
                marketing: true,
                functional: true
            });
            banner.remove();
            manageLnk.classList.remove('d-none');
            applyPrefs(defaults);
        });

        document.getElementById('btnSavePrefs').addEventListener('click', () => {
            const prefs = {
                essential: true,
                analytics: document.getElementById('ckAnalytics').checked,
                marketing: document.getElementById('ckMarketing').checked,
                functional: document.getElementById('ckFunctional').checked
            };
            savePrefs(prefs);
            banner.remove();
            bootstrap.Modal.getInstance(document.getElementById('cookieModal')).hide();
            manageLnk.classList.remove('d-none');
            applyPrefs(prefs);
        });

        /* Apply preferences (stub — replace with your own loaders) ------ */
        function applyPrefs(prefs) {
            // Example: load GA only if analytics allowed
            if (prefs.analytics && !window.gtagLoaded) {
                const s = document.createElement('script');
                s.src = 'https://www.googletagmanager.com/gtag/js?id=GA_MEASUREMENT_ID';
                s.async = true;
                document.head.appendChild(s);
                window.dataLayer = window.dataLayer || [];

                function gtag() {
                    dataLayer.push(arguments);
                }
                window.gtag = gtag;
                gtag('js', new Date());
                gtag('config', 'GA_MEASUREMENT_ID');
                window.gtagLoaded = true;
            }
            // similarly inject marketing / functional scripts on demand
        }
    })();
</script>
</body>

</html>